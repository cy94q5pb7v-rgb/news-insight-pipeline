# Copy to .env and fill in. NEVER commit real values.
TAVILY_API_KEYS=key1,key2            # Tavily search API keys (article extraction fallback)
SEARXNG_URL=http://127.0.0.1:8888    # self-hosted SearXNG metasearch JSON endpoint
LLM_AGENT_CMD=openclaw               # CLI used for LLM summarize/insight steps (see core/llm_agent.py)
LLM_AGENT_ID=trendwatch              # agent profile id
TELEGRAM_BOT_TOKEN=                  # optional, only if you wire delivery
TELEGRAM_CHAT_ID=100000000           # optional delivery target
APP_DIR=/opt/newsapp                 # base dir for data/db/state
